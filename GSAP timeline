gsap.registerPlugin(ScrollTrigger);

gsap.to(".card",{
opacity:1,
y:0,
duration:1,
stagger:0.1,
scrollTrigger:{
trigger:".hero",
start:"top 80%"
}
});

gsap.to(".stat-card",{
opacity:1,
y:0,
duration:1,
stagger:0.3,
scrollTrigger:{
trigger:".stats",
start:"top 80%"
}
});

const counters = document.querySelectorAll(".counter");

counters.forEach(counter => {

let target = +counter.getAttribute("data-target");

gsap.to(counter,{
innerText:target,
duration:2,
snap:{innerText:1},

scrollTrigger:{
trigger:".stats",
start:"top 80%"
},

onUpdate:function(){
counter.innerText = Math.floor(counter.innerText);
}

});

});

