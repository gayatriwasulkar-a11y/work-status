    <motion.div
      className="card"
      whileHover={{ y: -20 }}
      transition={{ duration: 0.3 }}
    >
      <h2>{title}</h2>
      <p>{description}</p>

      <AnimatedButton text={title} type={type} />
    </motion.div>
