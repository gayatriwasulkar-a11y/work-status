//components/AnimatedButton.jsx
import { motion } from "framer-motion";

function AnimatedButton({ text, type }) {
  const colors = {
    login: "blue",
    register: "green",
    delete: "red",
  };

  return (
    <motion.button
      className="btn"
      style={{ backgroundColor: colors[type] }}
      whileHover={{
        scale: 1.1,
        boxShadow: "0px 8px 20px rgba(0,0,0,0.2)",
      }}
      whileTap={{
        scale: 0.9,
      }}
      transition={{
        type: "spring",
        stiffness: 300,
      }}
    >
      {text}
    </motion.button>
  );
}

export default AnimatedButton;

